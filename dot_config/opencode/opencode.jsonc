{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "awk *": "allow",
      "cat *": "allow",
      "diff *": "allow",
      "echo *": "allow",
      "find *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git rev-list *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "rg *": "allow",
      "ruff *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "xargs grep *": "allow",
      "xargs head *": "allow",
      "xargs rg *": "allow",
      "poetry env info *": "allow",
      "poetry run mypy *": "allow",
      "poetry run pylint *": "allow",
      "poetry run pytest *": "allow",
      "poetry run ruff *": "allow",
      "python -m flake8 *": "allow",
      "python -m mypy *": "allow",
      "python -m pytest *": "allow",
      "uv run mypy *": "allow",
      "uv run pylint *": "allow",
      "uv run pytest *": "allow",
      "uv run ruff *": "allow"
    },
    "external_directory": {
      "~/.cache/pypoetry/virtualenvs/**": "allow",
      "~/.cache/uv/archive-v0/**": "allow"
    },
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "~/.cache/pypoetry/virtualenvs/**": "deny",
      "~/.cache/uv/archive-v0/**": "deny"
    }
  },
  "mcp": {
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp"
    }
  },
}
